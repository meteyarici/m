# ======================================================================
# m365 — Local Development Template (docker-compose ile uyumlu)
# ----------------------------------------------------------------------
# Kullanım:
#   cp .env.example.local .env
#   ./vendor/bin/sail artisan key:generate   # APP_KEY üretilir
#
# Bu dosya repo'ya commit edilir. GERÇEK şifre / secret KOYMA.
# Gerçek prod değerleri `.env` (gitignored) dosyasında tutulur.
# ======================================================================

APP_NAME=m365
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_DEBUG_ALLOWED_IPS=
APP_URL=http://localhost:8090
APP_ADMIN_URL=admin
APP_TIMEZONE=Europe/Istanbul
CACHE_EXPIRE=-1
VIEW_CACHE=false

APP_LOCALE=tr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_CURRENCY=TRY

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Veritabanı (docker-compose `mysql` servisiyle eşleşir) -----------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=m365
DB_USERNAME=m365
DB_PASSWORD=m365_dev_2026
DB_PREFIX=

# --- Session / Queue / Cache ------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# --- Redis (docker-compose `redis` servisi) ---------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RESPONSE_CACHE_ENABLED=true

# --- Mail (dev için Mailpit; prod'da SMTP'ye güncelle) ----------------
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null

MAIL_FROM_ADDRESS=shop@m365.local
MAIL_FROM_NAME=m365

ADMIN_MAIL_ADDRESS=admin@m365.local
ADMIN_MAIL_NAME=Admin

CONTACT_MAIL_ADDRESS=
CONTACT_MAIL_NAME=

# --- AWS S3 (opsiyonel) -----------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Vite --------------------------------------------------------------
VITE_APP_NAME=m365
VITE_HOST=localhost
VITE_PORT=5173

# --- Elasticsearch (docker-compose `elasticsearch` 7.17) --------------
ELASTICSEARCH_HOST=http://elasticsearch:9200

# --- Broadcast / Reverb (local dev placeholder'ları) ------------------
# Gerçek secret'ları `php artisan reverb:install` ile yeniden üret.
BROADCAST_CONNECTION=reverb
PUSHER_APP_ID=your-pusher-app-id
PUSHER_APP_KEY=your-pusher-key
PUSHER_APP_SECRET=your-pusher-secret
PUSHER_HOST=
PUSHER_PORT=80
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

OCTANE_SERVER=swoole

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Sail / Docker kullanıcı UID -------------------------------------
WWWUSER=1000
WWWGROUP=1000

# --- Host port forward'ları (adorelgo projesiyle çakışmayı önler) ----
# Container içi erişim aynı kalır (redis:6379, mysql:3306 vb.)
APP_PORT=8090
FORWARD_DB_PORT=33306
FORWARD_REDIS_PORT=16379
FORWARD_MAILPIT_PORT=11025
FORWARD_MAILPIT_DASHBOARD_PORT=18025
